# ═══════════════════════════════════════════════════════════════════════════
# PHATT Bridge — Web UI Environment Variables
# Add these to your existing .env file
# ═══════════════════════════════════════════════════════════════════════════

# Web server port (default 3100)
WEB_PORT=3100

# Anthropic API key for the chat interface.
# The chat proxies through the Express server so this key never reaches the browser.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
